// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`FetchToolRenderer handles empty packets array 1`] = `
<div
  data-testid="renderer-result"
>
  <div
    data-testid="status"
  >
    Fetching...
  </div>
  <div
    data-testid="content"
  >
    <div
      className="fetch-tool-renderer"
    >
      <div
        className="fetch-header"
      >
        <span
          className="fetch-icon"
        >
          📥
        </span>
        <strong>
          Fetching Documents
        </strong>
      </div>
    </div>
  </div>
</div>
`;

