exports[`FetchToolRenderer renders complete state 1`] = `
<div
  data-testid="renderer-result"
>
  <div
    data-testid="status"
  >
    Fetch complete
  </div>
  <div
    data-testid="content"
  >
    <div
      className="fetch-tool-renderer"
    >
      <div
        className="fetch-header"
      >
        <span
          className="fetch-icon"
        >
          📥
        </span>
        <strong>
          Fetching Documents
        </strong>
      </div>
      <div
        className="fetch-queries"
      >
        <div
          className="query-item"
        >
          search query
        </div>
      </div>
      <div
        className="fetch-results"
      >
        <div>
          Fetched 
          1
           documents
        </div>
      </div>
    </div>
  </div>
</div>
`;

